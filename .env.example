# PostHog analytics. Copy this file to .env.local.
# Project token: PostHog -> Settings -> Project -> Project token.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=

# PostHog instance URL. Leave unset for PostHog US Cloud. For self-hosted,
# set the instance URL (dev example: http://localhost:8000); in production it
# must be a publicly reachable HTTPS URL (e.g. a Cloudflare Tunnel hostname)
# because both visitor browsers and Vercel's rewrite proxy must reach it.
# See docs/POSTHOG-SELF-HOST.md.
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_ENVIRONMENT=local

# Local events log to the browser console when true. They are only sent to
# PostHog from localhost when CAPTURE_LOCALHOST is also true.
NEXT_PUBLIC_POSTHOG_DEBUG=true
NEXT_PUBLIC_POSTHOG_CAPTURE_LOCALHOST=false
