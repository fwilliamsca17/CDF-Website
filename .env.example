# cdf-website — Supabase + Resend environment variables.
# Copy to .env.local for dev (gitignored). Production values live in
# Vercel project settings; self-host runtime values live in the
# docker compose .env on the self-host box.

# Public — safe to ship to the browser.
NEXT_PUBLIC_PHASE_0=1
NEXT_PUBLIC_SUPABASE_URL=https://db.capital-df.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose. Used by route handlers + seed scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email — auth links + listing alerts)
RESEND_API_KEY=
RESEND_FROM_EMAIL="CDF Investor Group <alerts@listings.capital-df.com>"
